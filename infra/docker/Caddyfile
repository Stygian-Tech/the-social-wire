# Caddy reverse proxy for The Social Wire backend services.
# In production, replace {$CADDY_DOMAIN} with your actual domain (e.g. api.thesocialwire.com).
# Caddy automatically provisions TLS certificates via Let's Encrypt ACME.
# For local dev, Caddy uses its internal CA — trust it with: caddy trust

api.{$CADDY_DOMAIN} {
  reverse_proxy api:8080

  # Security headers
  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options "nosniff"
    X-Frame-Options "DENY"
    Referrer-Policy "strict-origin-when-cross-origin"
  }
}

portainer.{$CADDY_DOMAIN} {
  reverse_proxy portainer:9000

  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options "nosniff"
    X-Frame-Options "SAMEORIGIN"
  }
}
