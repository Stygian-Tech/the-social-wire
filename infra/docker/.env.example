# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Environment ───────────────────────────────────────────────────────────────
APP_ENV=local  # local | dev | prod

# ── Database ──────────────────────────────────────────────────────────────────
#
# LOCAL mode (APP_ENV=local) — SQLite, no Supabase needed
# --------------------------------------------------------
# Path inside the container where the SQLite database file is stored.
# The docker-compose.yml mounts a named volume at /data/sqlite.
SQLITE_DB_PATH=/data/sqlite/social-wire.sqlite

# DEV / PROD mode (APP_ENV=dev or prod) — Supabase Postgres
# ----------------------------------------------------------
# SUPABASE_DATABASE_URL and SQLITE_DB_PATH are mutually exclusive;
# the service uses whichever matches APP_ENV.
# Uncomment and fill in when deploying to dev/prod:
# SUPABASE_DATABASE_URL=postgresql://postgres:[PASSWORD]@db.byoeubizcjiyhlvrykzb.supabase.co:5432/postgres

# ── API ───────────────────────────────────────────────────────────────────────
PORT=8080

# ── ATProto ───────────────────────────────────────────────────────────────────
ATPROTO_PLC_URL=https://plc.directory

# ── Caddy ─────────────────────────────────────────────────────────────────────
CADDY_DOMAIN=localhost

# ── Docker ────────────────────────────────────────────────────────────────────
# `docker-compose` builds the API image from ../../services/api (no registry).
