{
  "name": "the-social-wire",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:web": "bun --cwd apps/web dev",
    "locks:freeze-text": "bun install --save-text-lockfile --frozen-lockfile --lockfile-only",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "clean": "turbo clean",
    "act:ci": "bash scripts/act/run-ci.sh",
    "act:supabase": "bash scripts/act/run-supabase-validate.sh",
    "act:all": "bash scripts/act/run-all.sh"
  },
  "devDependencies": {
    "turbo": "2.9.14"
  },
  "dependencies": {
    "latr-packages": "github:Stygian-Tech/latr-packages#a526ae3"
  },
  "packageManager": "bun@1.3.14"
}
