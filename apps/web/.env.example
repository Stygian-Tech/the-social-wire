# Copy to .env.local and adjust. No secrets are required for local ATProto OAuth loopback.
# See apps/web/README.md for behaviour details.

# Banner + OAuth mode: prod | dev | local (unset in next dev → local banner + loopback OAuth).
# Prefer NEXT_PUBLIC_* so the client bundle sees it; APP_ENV alone is forwarded at build via next.config.
# NEXT_PUBLIC_APP_ENV=dev
# APP_ENV=dev

# Optional override for hosted OAuth (preview/prod). Default: same-origin /client-metadata.json
# Do not set this to https://testing.thesocialwire.app/client-metadata.json — that URL is
# blocked for PDS discovery; testing uses the public gateway client_id automatically.
# NEXT_PUBLIC_ATPROTO_CLIENT_ID=https://thesocialwire.app/client-metadata.json

# NEXT_PUBLIC_ATPROTO_LOOPBACK_ORIGIN=http://127.0.0.1:3000
# NEXT_PUBLIC_ATPROTO_LOOPBACK_CALLBACK_PATH=/callback
# NEXT_PUBLIC_ATPROTO_LOOPBACK_FORCE=false

# Thin AppView (GDPR-safe Level-1 read index on Social Wire gateway)
# NEXT_PUBLIC_USE_THIN_APPVIEW=false
# NEXT_PUBLIC_SOCIALWIRE_API_URL=https://api.thesocialwire.app
