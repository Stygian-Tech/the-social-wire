meta {
  name: Post AppView Enroll Backfill
  type: http
  seq: 3
}

post {
  url: {{appviewBaseUrl}}/v1/appview/enroll
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{oauthAccessToken}}
  DPoP: {{dpopProof}}
  Content-Type: application/json
}

body:json {
  {
    "authorDids": [
      "{{authorDid}}"
    ]
  }
}

docs {
  Run after starting the worker to backfill recent entries for followed authors before relying on live Jetstream ingestion.
}
