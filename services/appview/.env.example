# The Social Wire AppView Fly environment
#
# Copy values into Fly with `fly secrets set ... --app <appview-app>`.
# Keep this file as documentation only; do not commit real credentials.
#
# Dev app:  the-social-wire-dev-appview
# Prod app: the-social-wire-prod-appview

# Runtime mode. Fly deployments must use `dev` or `prod`; `local` uses SQLite.
APP_ENV=dev

# HTTP bind settings. `PORT` should match `services/appview/fly.toml`.
PORT=8081
APPVIEW_PORT=8081
BIND_HOST=0.0.0.0

# Optional dotenv file path for local/manual runs. Fly secrets override file values.
DOTENV_PATH=.env

# Required when APP_ENV is `dev` or `prod`.
# Use the Supabase session pooler URI, not the direct db.* host.
# Format: postgresql://postgres.<project-ref>:<url-encoded-password>@aws-1-<region>.pooler.supabase.com:5432/postgres
SUPABASE_DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-us-east-1.pooler.supabase.com:5432/postgres

# Supabase session pooler connection cap guard. Keep this low because gateway,
# appview, and worker share the same pooler limit.
POSTGRES_MAX_CONNECTIONS=8

# Enables the Thin AppView read path. Required for AppView service startup.
ENABLE_THIN_APPVIEW=true

# Optional override for ATProto PLC discovery.
ATPROTO_PLC_URL=https://plc.directory

# Shared HMAC secret for Gateway -> AppView internal trust.
# Must be identical on gateway and appview.
GATEWAY_APPVIEW_INTERNAL_SECRET=<openssl-rand-hex-32>

# Optional Jetstream URL. Default subscribes to standard.site, Skyreader, read-state,
# and graph subscription collections.
THIN_APPVIEW_RELAY_WS_URL=wss://jetstream2.us-east.bsky.network/subscribe?wantedCollections=site.standard.document&wantedCollections=com.standard.document&wantedCollections=site.standard.entry&wantedCollections=com.standard.entry&wantedCollections=app.thesocialwire.entryReadState&wantedCollections=app.skyreader.feed.subscription&wantedCollections=site.standard.graph.subscription

# Content and read-mark retention windows in seconds.
THIN_APPVIEW_CONTENT_TTL_SECONDS=2592000
THIN_APPVIEW_READ_MARK_TTL_SECONDS=15552000

# Enrollment/backfill limits.
THIN_APPVIEW_MAX_ENROLL_AUTHORS=500
THIN_APPVIEW_MAX_ENROLL_RECORDS_PER_AUTHOR=2000
THIN_APPVIEW_MAX_ENROLL_CONCURRENCY=4

# Proactive backfill behavior.
THIN_APPVIEW_PROACTIVE_BACKFILL_ENABLED=true
THIN_APPVIEW_PROACTIVE_BACKFILL_INTERVAL_SECONDS=900
THIN_APPVIEW_PROACTIVE_BACKFILL_AUTHOR_LIMIT=40

# RSS/Skyreader ingest limits used by enrollment and feed polling.
THIN_APPVIEW_MAX_RSS_ITEMS_PER_FEED=200
THIN_APPVIEW_RSS_FEED_POLL_ENABLED=true
THIN_APPVIEW_RSS_FEED_POLL_INTERVAL_SECONDS=1800
THIN_APPVIEW_RSS_FEED_POLL_FEED_LIMIT=20

# Local-only fallback when APP_ENV=local. Fly should use SUPABASE_DATABASE_URL.
SQLITE_DB_PATH=./social-wire-appview.sqlite
