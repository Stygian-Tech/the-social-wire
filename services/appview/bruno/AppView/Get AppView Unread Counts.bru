meta {
  name: Get AppView Unread Counts
  type: http
  seq: 22
}

get {
  url: {{baseUrl}}/v1/appview/unread-counts?authorDid={{authorDid}}&publicationAtUri={{publicationAtUri}}
  body: none
  auth: none
}

headers {
  Authorization: Bearer {{oauthAccessToken}}
  DPoP: {{dpopProof}}
}

docs {
  Alternative query: `publicationIds=id1,id2` for sidebar badge counts by publication id.
}
