# The Social Wire Gateway Fly environment
#
# Copy values into Fly with `fly secrets set ... --app <gateway-app>`.
# Keep this file as documentation only; do not commit real credentials.
#
# Dev app:  the-social-wire-dev-gateway
# Prod app: the-social-wire-prod-gateway

# Runtime mode. Fly deployments must use `dev` or `prod`; `local` uses SQLite.
APP_ENV=dev

# HTTP bind settings. `PORT` should match `services/gateway/fly.toml`.
PORT=8080
BIND_HOST=0.0.0.0

# Optional dotenv file path for local/manual runs. Fly secrets override file values.
DOTENV_PATH=.env

# Required when APP_ENV is `dev` or `prod`.
# Use the Supabase session pooler URI, not the direct db.* host.
# Format: postgresql://postgres.<project-ref>:<url-encoded-password>@aws-1-<region>.pooler.supabase.com:5432/postgres
SUPABASE_DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-us-east-1.pooler.supabase.com:5432/postgres

# Supabase session pooler connection cap guard. Keep this low because gateway,
# appview, and worker share the same pooler limit.
POSTGRES_MAX_CONNECTIONS=8

# Optional override for ATProto PLC discovery.
ATPROTO_PLC_URL=https://plc.directory

# AppView proxy target. Required for the gateway to serve /v1/appview/* and
# /v1/publications/* from the distributed AppView service.
APPVIEW_BASE_URL=https://the-social-wire-dev-appview.fly.dev

# Shared HMAC secret for Gateway -> AppView internal trust.
# Must be identical on gateway and appview.
GATEWAY_APPVIEW_INTERNAL_SECRET=<openssl-rand-hex-32>

# OAuth metadata origin for the web client. Set to the public API origin that
# hosts /oauth/client-metadata.json.
OAUTH_PUBLIC_ORIGIN=https://api.testing.thesocialwire.app

# Optional explicit CORS allow-list for browser clients. Comma/newline/space
# delimited. If unset, the gateway falls back to OAUTH_PUBLIC_ORIGIN.
CORS_ALLOWED_ORIGINS=https://testing.thesocialwire.app,https://thesocialwire.app

# Optional origin override used only for /ios-client-metadata.json.
# Set when the iOS client metadata is served from a different API host.
OAUTH_IOS_METADATA_ORIGIN=https://api.testing.thesocialwire.app

# Hosted OAuth policy. Tokens from unknown clients are allowed unless this is true.
OAUTH_GATEWAY_REQUIRE_KNOWN_CLIENT=true

# Comma/newline/space-delimited client IDs accepted when known-client policy is enabled.
OAUTH_GATEWAY_ALLOWED_CLIENT_IDS=https://api.testing.thesocialwire.app/oauth/client-metadata.json,https://api.testing.thesocialwire.app/ios-client-metadata.json

# Optional comma/newline/space-delimited accepted token audiences.
# Leave empty unless narrowing access-token audiences deliberately.
OAUTH_GATEWAY_ALLOWED_AUDIENCES=

# Optional JWKS JSON used when an OAuth issuer omits signing keys from metadata.
# Usually unset.
OAUTH_ACCESS_TOKEN_SUPPLEMENTAL_JWKS_JSON=

# Optional L@tr Link iOS proxy. When unset, /v1/latr/* routes are not registered.
LATR_IOS_PROXY_URL=https://api.latr.link
LATR_IOS_PROXY_CLIENT_ID=<latr-client-id>
LATR_IOS_PROXY_API_KEY=<latr-api-key>

# Alternative to LATR_IOS_PROXY_CLIENT_ID + LATR_IOS_PROXY_API_KEY for official
# first-party credentials.
LATR_IOS_PROXY_CLIENT_CREDENTIAL=

# Deprecated aliases accepted by the code for early parity deploys.
# Prefer LATR_IOS_PROXY_* on Fly.
LATR_GATEWAY_URL=
LATR_GATEWAY_CLIENT_ID=
LATR_GATEWAY_API_KEY=
LATR_GATEWAY_CLIENT_CREDENTIAL=
LATR_GATEWAY_OFFICIAL_CLIENT_CREDENTIALS=

# Local-only fallback when APP_ENV=local. Fly should use SUPABASE_DATABASE_URL.
SQLITE_DB_PATH=./social-wire.sqlite
