meta {
  name: Post Publication Resolve
  type: http
  seq: 32
}

post {
  url: {{baseUrl}}/v1/publications/resolve
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{oauthAccessToken}}
  DPoP: {{dpopProof}}
  Content-Type: application/json
}

body:json {
  {
    "input": "{{resolveInput}}"
  }
}

docs {
  Resolves a URL, handle, or AT-URI into a standard.site publication or RSS feed target.
}
