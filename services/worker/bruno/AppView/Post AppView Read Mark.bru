meta {
  name: Post AppView Read Mark
  type: http
  seq: 12
}

post {
  url: {{baseUrl}}/v1/appview/read-marks
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{oauthAccessToken}}
  DPoP: {{dpopProof}}
  Content-Type: application/json
}

body:json {
  {
    "subjectUri": "{{entrySubjectUri}}",
    "readAt": "{{readMarkAt}}"
  }
}

docs {
  Verifies read-mark write-through to the index the worker TTL job also maintains.
}
