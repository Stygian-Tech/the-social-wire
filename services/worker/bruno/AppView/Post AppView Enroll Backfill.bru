meta {
  name: Post AppView Enroll Backfill
  type: http
  seq: 11
}

post {
  url: {{baseUrl}}/v1/appview/enroll
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{oauthAccessToken}}
  DPoP: {{dpopProof}}
  Content-Type: application/json
}

body:json {
  {
    "authorDids": [
      "{{authorDid}}"
    ]
  }
}

docs {
  Triggers API-side backfill indexing for followed authors. Worker firehose handles ongoing ingestion afterward.
}
