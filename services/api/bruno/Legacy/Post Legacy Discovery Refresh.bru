meta {
  name: Post Legacy Discovery Refresh
  type: http
  seq: 90
}

post {
  url: {{baseUrl}}/discovery/refresh
  body: none
  auth: none
}

headers {
  Authorization: Bearer {{oauthAccessToken}}
  DPoP: {{dpopProof}}
}

docs {
  Requires `ENABLE_LEGACY_CONTENT_API=true`. Starts async discovery refresh for the authenticated user.
}

