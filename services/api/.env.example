# Copy to `.env` in this directory (`services/api`) or set `DOTENV_PATH` to another file.
# Process environment always overrides these values.

APP_ENV=local
PORT=8080
# BIND_HOST=0.0.0.0

# Optional: SPA origin for **`redirect_uris`** on **`/oauth/client-metadata.json`** when the web app
# is on another host (e.g. `https://testing.thesocialwire.app` while metadata is served from `api.*`).
# Does **not** apply to `/ios-client-metadata.json` — that route uses request Host unless OAUTH_IOS_METADATA_ORIGIN is set.
# OAUTH_PUBLIC_ORIGIN=https://testing.thesocialwire.app

# Optional: overrides client_id origin for **`/ios-client-metadata.json`** only (rare: tunnel with wrong Host).
# Leave unset on api.* deploys so client_id matches the URL the app uses (avoids invalid_client_metadata).
# OAUTH_IOS_METADATA_ORIGIN=https://your-ios-tunnel.example
#
# Native `redirect_uris` in `/ios-client-metadata.json` always use the **`client_id` host reversed** per ATProto
# (e.g. api.testing.thesocialwire.app → `app.thesocialwire.testing.api:/oauth/callback`).

# Required when APP_ENV is dev or prod
# SUPABASE_DATABASE_URL=postgresql://postgres:password@db.project.supabase.co:5432/postgres

# Optional
# SQLITE_DB_PATH=./social-wire.sqlite
# ATPROTO_PLC_URL=https://plc.directory

# Thin AppView (GDPR-safe Level-1 read index; requires Supabase in dev/prod)
# ENABLE_THIN_APPVIEW=false
# THIN_APPVIEW_RELAY_WS_URL=wss://jetstream2.us-east.bsky.network/subscribe?wantedCollections=...
# THIN_APPVIEW_CONTENT_TTL_SECONDS=2592000
# THIN_APPVIEW_READ_MARK_TTL_SECONDS=15552000
# THIN_APPVIEW_MAX_ENROLL_AUTHORS=500

# OAuth gateway allowlists (hosted first-party clients only)
# OAUTH_GATEWAY_ALLOWED_CLIENT_IDS=https://thesocialwire.app/client-metadata.json,https://api.thesocialwire.app/ios-client-metadata.json
# OAUTH_GATEWAY_ALLOWED_AUDIENCES=https://api.thesocialwire.app
# OAUTH_GATEWAY_REQUIRE_KNOWN_CLIENT=false
