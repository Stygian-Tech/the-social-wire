# Local-only secrets for `nektos/act`. Copy to `.secrets` (gitignored):
#   cp scripts/act/.secrets.example scripts/act/.secrets
#
# Deploy / Supabase push scripts use `--secret-file scripts/act/.secrets`.
# Dry-run workflow resolution only (no secrets): -n on run-supabase-push-*.sh

FLY_API_TOKEN=
# Optional when the token has access to multiple Fly orgs:
# FLY_ORG=personal
# FLY_GATEWAY_APP_DEV=the-social-wire-dev-gateway
# FLY_GATEWAY_APP_PROD=the-social-wire-prod-gateway
# FLY_APPVIEW_APP_DEV=the-social-wire-dev-appview
# FLY_APPVIEW_APP_PROD=the-social-wire-prod-appview
# FLY_APPVIEW_WORKER_APP_DEV=the-social-wire-dev-appview-worker
# FLY_APPVIEW_WORKER_APP_PROD=the-social-wire-prod-appview-worker

SUPABASE_ACCESS_TOKEN=
SUPABASE_DEV_PROJECT_REF=
# Preferred: Session pooler URI (Connect → Session mode, port 5432)
SUPABASE_DEV_DATABASE_URL=
SUPABASE_DEV_DB_PASSWORD=
SUPABASE_PROD_PROJECT_REF=
SUPABASE_PROD_DATABASE_URL=
SUPABASE_PROD_DB_PASSWORD=
